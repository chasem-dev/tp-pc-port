{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: configure PC port",
      "type": "shell",
      "command": "cmake -S pc -B pc/build",
      "group": "build"
    },
    {
      "label": "cmake: build PC port",
      "type": "shell",
      "command": "cmake --build pc/build --parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
